PROJECT_NAME=VyaparSetu
PROJECT_VERSION=0.1.0
API_V1_PREFIX=/api/v1

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=vyaparsetu
POSTGRES_PASSWORD=vyaparsetu
POSTGRES_DB=vyaparsetu
# DATABASE_URL=postgresql+psycopg://vyaparsetu:vyaparsetu@localhost:5432/vyaparsetu

SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=[]

# Optional one-time bootstrap admin. Set these before running:
# python -m app.cli create-first-admin
# FIRST_ADMIN_EMAIL=admin@example.com
# FIRST_ADMIN_PASSWORD=change-this-password
# FIRST_ADMIN_FULL_NAME=VyaparSetu Admin

UPLOAD_DIR=storage/uploads
MAX_UPLOAD_FILE_SIZE_BYTES=10485760

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

AI_PROVIDER=mock
DOCUMENT_INTELLIGENCE_ENABLED=true
OPENAI_API_KEY=
NOTIFICATION_PROVIDER=mock
ADMIN_NOTIFICATION_EMAIL=admin@example.com

PRICING_GST=Contact us
PRICING_FSSAI=Contact us
PRICING_UDYAM=Contact us
RATE_LIMIT_PER_MINUTE=120
ENVIRONMENT=development
