PROJECT_NAME=VyaparSetu
PROJECT_VERSION=1.0.0
ENVIRONMENT=production
API_V1_PREFIX=/api/v1

POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=vyaparsetu
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=vyaparsetu
DATABASE_URL=postgresql+psycopg://vyaparsetu:replace-with-strong-password@db:5432/vyaparsetu
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=["https://your-domain.com"]

UPLOAD_DIR=storage/uploads
MAX_UPLOAD_FILE_SIZE_BYTES=10485760

DOCUMENT_INTELLIGENCE_ENABLED=false
AI_PROVIDER=mock
OPENAI_API_KEY=
NOTIFICATION_PROVIDER=email
ADMIN_NOTIFICATION_EMAIL=ops@your-domain.com

PRICING_GST=Configure before launch
PRICING_FSSAI=Configure before launch
PRICING_UDYAM=Configure before launch
RATE_LIMIT_PER_MINUTE=120

NEXT_PUBLIC_API_BASE_URL=https://your-domain.com/api/v1
